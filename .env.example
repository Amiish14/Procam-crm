# Procam ProConnect CRM — Environment Variables
# Copy this to .env and fill in values

# Flask secret key (change in production!)
SECRET_KEY=procam-crm-secret-change-me-2025

# Database URL
# SQLite for local dev:
DATABASE_URL=sqlite:///procam_crm.db
# PostgreSQL for production (Render provides this automatically):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Microsoft 365 / Outlook token for news intelligence fetch
# Get via OAuth2 flow from Azure AD app registration
MS365_TOKEN=

# Debug mode (never true in production)
DEBUG=false

# Port (Render sets this automatically)
PORT=5000
